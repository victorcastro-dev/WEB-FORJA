# Obrigatória em produção. Use a URL canônica final, sem barra no fim.
NEXT_PUBLIC_SITE_URL=https://webforja.com.br

# Obrigatória em produção para CTA flutuante, footer e fallback de leads.
# Use somente números, com DDI e DDD. Ex.: 5511912345678
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Opcional. Recebe os leads validados via POST JSON.
# Se ficar vazia, o formulário continua útil com fallback para WhatsApp.
LEADS_WEBHOOK_URL=

# Opcional em desenvolvimento.
DEV_ALLOWED_ORIGINS=

# Opcional. ID da propriedade web do Google Analytics 4.
# Ex.: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Opcional. ID do Google Ads para futura importação ou disparo de conversão.
# Ex.: AW-1234567890
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Opcional. Label da conversão de lead no Google Ads para disparo direto via gtag.
NEXT_PUBLIC_GOOGLE_ADS_LEAD_LABEL=
